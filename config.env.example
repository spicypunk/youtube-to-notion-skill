# Copy this file to config.env and fill in your own values.
# config.env is gitignored — never commit it.
#
# Setup:
#   1. Create a Notion integration at https://www.notion.so/profile/integrations
#      and copy the "Internal Integration Secret" into NOTION_TOKEN below.
#   2. Open the Notion page where you want video notes to be created as
#      child pages. Click "..." → "Connections" → add your integration so
#      it has write access.
#   3. Copy the page's URL — the 32-char hex string before "?source=..." is
#      your NOTION_PARENT_PAGE_ID. Strip any hyphens.
#
# Example URL: https://www.notion.so/My-Notes-336a8c1feb0680c8b74fda201bff223e
# Parent ID:                            336a8c1feb0680c8b74fda201bff223e

NOTION_TOKEN=ntn_replace_me_with_your_token
NOTION_PARENT_PAGE_ID=replace_me_with_your_32_char_page_id
